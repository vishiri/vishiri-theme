{
  "name": "vishiri-theme",
  "displayName": "Vishiri Theme",
  "description": "Theme by vishiri",
  "publisher": "elvanos",
  "icon": "images/logo.png",
  "version": "1.1.1",
  "main": "./extension.js",
  "activationEvents": [
    "onStartupFinished"
  ],
  "repository": "https://github.com/vishiri/vishiri-theme.git",
  "scripts": {
    "organize-theme": "node scripts/organize-theme.mjs"
  },
  "devDependencies": {
    "json5": "^2.2.3"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Themes",
    "Programming Languages"
  ],
  "contributes": {
    "grammars": [
      {
        "scopeName": "vishiri.inject.markdown.blockquote-gt",
        "path": "./syntaxes/markdown-blockquote-gt.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      },
      {
        "scopeName": "vishiri.inject.markdown.definition-list-colon",
        "path": "./syntaxes/markdown-definition-list-colon.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ]
      },
      {
        "scopeName": "vishiri.inject.php.self-scope-resolution",
        "path": "./syntaxes/php-self-scope-resolution.tmLanguage.json",
        "injectTo": [
          "source.php"
        ]
      }
    ],
    "themes": [
      {
        "label": "Vishiri Theme",
        "uiTheme": "vs-dark",
        "path": "./themes/Vishiri Theme-color-theme.json"
      }
    ]
  }
}